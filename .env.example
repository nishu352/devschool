# Frontend (Vite) - copy to .env.local
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
# (Legacy name also supported: VITE_SUPABASE_ANON_KEY)

# Auth setup in Supabase Dashboard (Authentication > Providers):
# - Enable Google and add OAuth client id/secret.
# - Enable Phone and configure SMS (Twilio, MessageBird, etc.).
# - URL Configuration: add Site URL and Redirect URLs, e.g.
#   http://localhost:5173/login
#   https://your-production-domain/login

# Backend (Express) - copy to .env
# Optional; if omitted, tutor uses deterministic fallback mode.
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=your_openrouter_key
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENAI_API_KEY=your_openai_key
# OPENAI_MODEL=gpt-4o-mini
# CORS_ORIGIN=http://localhost:5173
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# DASHBOARD_TABLE=dashboard_overview

